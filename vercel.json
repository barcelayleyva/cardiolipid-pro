{
“rewrites”: [
{ “source”: “/(.)”, “destination”: “/index.html” }
],
“headers”: [
{
“source”: “/icon-(.).png”,
“headers”: [
{ “key”: “Content-Type”, “value”: “image/png” },
{ “key”: “Cache-Control”, “value”: “public, max-age=31536000” }
]
},
{
“source”: “/manifest.json”,
“headers”: [
{ “key”: “Content-Type”, “value”: “application/manifest+json” }
]
}
]
}
